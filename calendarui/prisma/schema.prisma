generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id          String   @id @default(uuid())
  userId      String
  title       String
  startTime   DateTime
  endTime     DateTime
  description String?  
  owner	      String?
  googleId    String?  @unique
  createdAt   DateTime @default(now())
}